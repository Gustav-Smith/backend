datasource db {
  provider = "postgresql"
}

model Visita {
  id          Int       @id @default(autoincrement())
  data        DateTime

  // Campos do padrão de visita
  observacao  String?   // renomeado de observacoes para observacao

  // Cidade e Estado ficam na Visita pois podem ser diferentes da loja
  cidade      String
  estado      String

  // Chaves estrangeiras
  promotorId  Int
  lojaId      Int

  // Relacionamentos
  promotor    Promotor  @relation(fields: [promotorId], references: [id])
  loja        Loja      @relation(fields: [lojaId], references: [id])

  status      String    @default("pendente")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Promotor {
  id Int @id @default(autoincrement())
  nome String
  visitas Visita[]
}

model Loja {
  id Int @id @default(autoincrement())
  nome String
  visitas Visita[]
}